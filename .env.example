# ============================================================
# 업비트 자동매매 시스템 v3.0 — 환경 변수 설정 파일
# 이 파일을 복사하여 .env로 이름을 변경한 후 실제 값을 입력하세요.
# ⚠ .env 파일은 절대 Git에 커밋하지 마세요!
# ============================================================

# ─── 데이터베이스 설정 ───
POSTGRES_USER=upbit_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=upbit_trading
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis 설정 (Celery 브로커 + 캐시) ───
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─── JWT 인증 설정 ───
# openssl rand -hex 32 명령으로 생성하세요
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── API 키 암호화 (AES-256-GCM) ───
# openssl rand -hex 32 명령으로 생성하세요 (반드시 64자 hex)
ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── 관리자 초기 계정 ───
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_admin_password

# ─── CORS 허용 도메인 ───
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── 텔레그램 봇 설정 ───
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# ─── 서버 설정 ───
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ─── 프론트엔드 설정 ───
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws
